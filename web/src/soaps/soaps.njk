---
pagination:
  data: soaps
  size: 1
  alias: soap
permalink: "/coleccion/{{ soap.slug }}/index.html"
eleventyComputed:
  title: "Jabón de {{ soap.name }}"
  description: "{{ soap.metaDesc if soap.metaDesc else soap.tagline ~ ' — aum. jabones botánicos artesanales. Producción en Subachoque, Colombia.' }}"
---

{% include "components/cert-icons.njk" %}

  <nav class="breadcrumb" aria-label="Ruta de navegación">
    <ol class="breadcrumb__list">
      <li class="breadcrumb__item"><a href="/">aum.</a></li>
      <li class="breadcrumb__item"><a href="/coleccion/">Colección</a></li>
      <li class="breadcrumb__item" aria-current="page">{{ soap.name }}</li>
    </ol>
  </nav>

  <section class="hero" aria-labelledby="product-name">
    <div class="hero__img-wrap">
      <img src="/images/{{ soap.heroImage }}"
        alt="Jabón de {{ soap.name }} con cristal de {{ soap.name }}"
        class="hero__img" loading="eager" fetchpriority="high" decoding="async"
        width="1920" height="1280"
        sizes="(max-width: 768px) 100vw, 55vw">
    </div>
    <div class="hero__body">
      <span class="hero__meta">{{ soap.number }} / 07 &nbsp;·&nbsp; Crystal Infused Face and Body Soap</span>
      <span class="hero__center">{{ soap.center }}</span>
      <h1 class="hero__name" id="product-name">{{ soap.name }}</h1>
      <p class="hero__tagline">{{ soap.tagline }}</p>
      <a href="https://wa.me/{{ site.waNumber }}?text={{ soap.waText }}"
         class="hero__btn" target="_blank" rel="noopener noreferrer"
         aria-label="Pedir Jabón de {{ soap.name }} por WhatsApp"
         data-track="whatsapp-cta" data-track-soap="{{ soap.slug }}" data-track-location="hero">
        Pedir por WhatsApp
      </a>
      <p class="hero__price">{{ site.price }}</p>
      <p class="hero__payments">Nequi &nbsp;·&nbsp; Llaves (Bancolombia)</p>
    </div>
  </section>

  <section class="gallery" aria-label="Galería de {{ soap.name }}">
    <div class="gallery__strip">
      {% set images = soap.galleryImages if soap.galleryImages else [
        { "src": soap.packageImage, "alt": soap.name ~ " — empaque" },
        { "src": soap.crystalImage, "alt": soap.name ~ " — cristal" },
        { "src": soap.ritualImage, "alt": soap.name ~ " — ritual" }
      ] %}
      {% for img in images %}
      <button class="gallery__thumb" data-index="{{ loop.index0 }}" aria-label="Ver imagen {{ loop.index }} de {{ images | length }}">
        <img src="/images/{{ img.src }}"
          alt="{{ img.alt }}"
          width="400" height="400"
          loading="lazy" decoding="async">
      </button>
      {% endfor %}
    </div>
  </section>

  <div class="lightbox" role="dialog" aria-modal="true" aria-label="Galería de imágenes" hidden>
    <button class="lightbox__close" aria-label="Cerrar galería">&times;</button>
    <button class="lightbox__prev" aria-label="Imagen anterior">&#8592;</button>
    <button class="lightbox__next" aria-label="Imagen siguiente">&#8594;</button>
    <div class="lightbox__stage">
      <img class="lightbox__img" src="" alt="">
    </div>
    <div class="lightbox__counter"></div>
  </div>

  <section class="sec" aria-labelledby="sec-historia">
    <h2 class="sec__label" id="sec-historia">Historia del jabón</h2>
    <hr class="sec__rule">
    <div class="narr rv">
      <p class="narr__pull">{{ soap.pullQuote }}</p>
      {%- set narrativeParas = soap.narrative.split('\n\n') %}
      {%- for para in narrativeParas %}
      <p class="narr__body">{{ para }}</p>
      {%- endfor %}
    </div>
  </section>

  <section class="sec" aria-label="Ingredientes">
    <h2 class="sec__label">Ingredientes</h2>
    <hr class="sec__rule">
    <div class="ingr rv">
      <div>
        <span class="ingr__col-label">Aceites esenciales</span>
        <ul role="list">
          {% for oil in soap.oils %}
          <li class="oil-row">
            <span class="oil-common">{{ oil.common }}</span>
            <span class="oil-inci" lang="la">{{ oil.inci }}</span>
          </li>
          {% endfor %}
        </ul>
      </div>
      <div>
        <span class="ingr__col-label">Base — todos los jabones</span>
        <ul role="list">
          {% for ing in site.baseIngredients %}
          <li class="inci-row" lang="la">{{ ing }}</li>
          {% endfor %}
        </ul>
        <p class="ingr__note">Peso neto: 110 gr</p>
      </div>
    </div>
  </section>

  <section class="cblock" aria-label="El cristal">
    <div class="cblock__inner">
      <div class="cblock__photo rv">
        <img src="/images/{{ soap.crystalImage }}"
          alt="{{ soap.crystalPoetic }}"
          loading="lazy" decoding="async"
          width="600" height="800">
      </div>
      <h2 class="cblock__crystal-name rv">{{ soap.name }}</h2>
      <div class="rv">
        <p class="cblock__label">El cristal</p>
        <p class="cblock__desc">{{ soap.crystalDesc }}</p>
        <p class="cblock__disclaimer">Cada jabón está acompañado por un cristal como símbolo físico de intención. No es un componente terapéutico, sino un recordatorio tangible del momento que eliges crear.</p>
      </div>
    </div>
  </section>

  {% if soap.reflection %}
  <section class="sec sec--reflection" aria-label="Reflexión — {{ soap.center }}">
    <h2 class="sec__label">{{ soap.center }}</h2>
    <hr class="sec__rule">
    <div class="reflection rv">
      {%- set reflectionParas = soap.reflection.split('\n\n') %}
      {%- for para in reflectionParas %}
      <p class="reflection__{% if loop.last %}question{% else %}body{% endif %}">{{ para }}</p>
      {%- endfor %}
    </div>
  </section>
  {% endif %}

  <div class="certs" aria-label="Certificaciones">
    <div class="cert"><svg class="cert__icon"><use href="#icon-leaf"/></svg><span>100% Natural</span></div>
    <div class="cert"><svg class="cert__icon"><use href="#icon-rabbit"/></svg><span>Cruelty Free</span></div>
    <div class="cert"><svg class="cert__icon"><use href="#icon-shield-x"/></svg><span>Libre de Parabenos</span></div>
    <div class="cert"><svg class="cert__icon"><use href="#icon-drop-x"/></svg><span>Libre de Sulfatos</span></div>
    <div class="cert"><svg class="cert__icon"><use href="#icon-hands"/></svg><span>Hecho a Mano</span></div>
    <div class="cert"><svg class="cert__icon"><use href="#icon-no-palm"/></svg><span>Sin Aceite de Palma</span></div>
  </div>

  <nav class="pnav" aria-label="Navegación entre jabones">
    {% if soap.prevSlug %}
    <a href="/coleccion/{{ soap.prevSlug }}/" class="pnav__item pnav__item--prev"
       aria-label="Anterior: {{ soap.prevName }}">
      <span class="pnav__dir">&#8592; Anterior</span>
      <span class="pnav__name">{{ soap.prevName }}</span>
    </a>
    {% else %}
    <span class="pnav__item pnav__item--empty"></span>
    {% endif %}

    <a href="/coleccion/" class="pnav__mid">Ver colección completa</a>

    {% if soap.nextSlug %}
    <a href="/coleccion/{{ soap.nextSlug }}/" class="pnav__item pnav__item--next"
       aria-label="Siguiente: {{ soap.nextName }}">
      <span class="pnav__dir">Siguiente &#8594;</span>
      <span class="pnav__name">{{ soap.nextName }}</span>
    </a>
    {% else %}
    <span class="pnav__item pnav__item--empty"></span>
    {% endif %}
  </nav>

  <script src="/js/fit-text.js" defer></script>
  <script src="/js/product.js" defer></script>
