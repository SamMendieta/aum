<header role="banner">
  <nav class="nav {% if navMode == 'product' %}nav--product{% elif navLightHero %}nav--editorial nav--light-hero{% else %}nav--editorial{% endif %}" id="nav" aria-label="Navegación principal">
    <a href="/" class="nav__logo" aria-label="aum. — Inicio">aum.</a>
    <ul class="nav__links" role="list">
      {% for link in site.nav %}
      <li><a href="{{ link.href }}"
        {% if page.url == link.href %}aria-current="page"{% endif %}>
        {{ link.label }}
      </a></li>
      {% endfor %}
      <li>
        <a href="{{ site.whatsapp.baseUrl }}?text={{ site.whatsapp.defaultMessage }}"
           target="_blank" rel="noopener noreferrer"
           aria-label="Contactar aum. por WhatsApp">
          WhatsApp
        </a>
      </li>
    </ul>
    <button class="nav__toggle" id="navToggle"
      aria-label="Abrir menú de navegación"
      aria-expanded="false"
      aria-controls="navDrawer">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </nav>

  <div class="nav__drawer" id="navDrawer"
    role="dialog"
    aria-label="Menú de navegación"
    aria-modal="true"
    aria-hidden="true">
    <nav aria-label="Menú principal">
      <a href="/">Inicio</a>
      {% for link in site.nav %}
      <a href="{{ link.href }}">{{ link.label }}</a>
      {% endfor %}
      <a href="{{ site.whatsapp.baseUrl }}" target="_blank" rel="noopener noreferrer">WhatsApp</a>
    </nav>
    <div class="nav__drawer-foot" aria-hidden="true">
      <p>{{ site.tagline }}</p>
    </div>
  </div>
</header>
