        C 146 292, 148 286, 150 280

        M 158 92
        C 162 94, 168 98, 172 102
        C 180 112, 192 128, 200 144
        C 208 160, 212 176, 214 188
        C 216 200, 220 212, 226 224
        C 232 240, 242 254, 254 266
        C 266 278, 272 290, 270 302
        C 268 314, 260 322, 246 326
