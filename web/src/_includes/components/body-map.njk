        C 154 292, 152 286, 150 280
      " stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    </svg>

    {# 7 crystal points positioned along the spine #}
    {% set points = [
      { id: "cx-quartz", y: "32", center: "Corona", name: "Cuarzo Transparente", num: "01", slug: "cuarzo-transparente", cx: "var(--cx-quartz)" },
      { id: "cx-amethyst", y: "68", center: "Tercer Ojo", name: "Amatista", num: "02", slug: "amatista", cx: "var(--cx-amethyst)" },
      { id: "cx-sodalite", y: "100", center: "Garganta", name: "Sodalita", num: "03", slug: "sodalita", cx: "var(--cx-sodalite)" },
      { id: "cx-aventurine", y: "148", center: "Corazon", name: "Aventurina", num: "04", slug: "aventurina", cx: "var(--cx-aventurine)" },
      { id: "cx-citrine", y: "192", center: "Plexo Solar", name: "Citrino", num: "05", slug: "citrino", cx: "var(--cx-citrine)" },
      { id: "cx-carnelian", y: "232", center: "Sacro", name: "Cornalina", num: "06", slug: "cornalina", cx: "var(--cx-carnelian)" },
      { id: "cx-jasper", y: "272", center: "Raiz", name: "Jaspe Brechado", num: "07", slug: "jaspe-brechado", cx: "var(--cx-jasper)" }
    ] %}

    {% for p in points %}
    <a href="/coleccion/{{ p.slug }}/" class="body-map__point" style="--point-y: {{ p.y }}px; --cx-point: {{ p.cx }}" aria-label="{{ p.name }} — Centro {{ p.center }}">
      <svg class="body-map__crystal" aria-hidden="true"><use href="#{{ p.id }}"/></svg>
      <span class="body-map__line" aria-hidden="true"></span>
      <span class="body-map__label">
        <span class="body-map__num">{{ p.num }}</span>
        <span class="body-map__name">{{ p.name }}</span>
        <span class="body-map__center">Centro {{ p.center }}</span>
      </span>
    </a>
    {% endfor %}
  </div>
</div>
