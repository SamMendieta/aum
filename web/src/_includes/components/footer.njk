<footer class="footer footer--editorial" role="contentinfo">
  <div class="footer__inner">
    <div class="footer__top">
      <a href="/" class="footer__logo" aria-label="aum. — Inicio">{% include "components/logo.njk" %}</a>
      <a href="{{ site.whatsapp.baseUrl }}?text={{ site.whatsapp.orderMessage }}"
         target="_blank" rel="noopener noreferrer"
         class="footer__wa"
         aria-label="Hacer un pedido por WhatsApp"
         data-track="whatsapp-cta" data-track-location="footer">
        Pedir por WhatsApp
      </a>
    </div>
    <nav class="footer__links" aria-label="Navegación del pie de página">
      <a class="footer__link" href="/coleccion/jaspe-brechado/">Jaspe Brechado</a>
      <a class="footer__link" href="/coleccion/cornalina/">Cornalina</a>
      <a class="footer__link" href="/coleccion/citrino/">Citrino</a>
      <a class="footer__link" href="/coleccion/aventurina/">Aventurina</a>
      <a class="footer__link" href="/coleccion/sodalita/">Sodalita</a>
      <a class="footer__link" href="/coleccion/amatista/">Amatista</a>
      <a class="footer__link" href="/coleccion/cuarzo-transparente/">Cuarzo Transparente</a>
      <span class="footer__sep" aria-hidden="true">·</span>
      <a class="footer__link" href="/nosotros/">Nosotros</a>
      <a class="footer__link" href="/contacto/">Contacto</a>
      <a class="footer__link" href="{{ site.instagram }}" target="_blank" rel="noopener noreferrer">Instagram</a>
    </nav>
    <div class="footer__bottom">
      <p class="footer__copy">{{ site.copyright }} &nbsp;·&nbsp; <a class="footer__link" href="/privacidad/" style="text-transform:none;letter-spacing:0.06em;color:rgba(239,234,223,0.3)">Privacidad</a></p>
      <p class="footer__origin">{{ site.origin }}</p>
    </div>
  </div>
</footer>
