---
layout: base.njk
navMode: "product"
---
{% block pagecss %}
<style>:root { --cx: {{ soap.cx }}; --cx-text: {{ soap.cxText or soap.cx }}; }</style>
<link rel="stylesheet" href="/css/product.css">
{% endblock %}

{% block ogmeta %}
<meta property="og:type" content="product">
<meta property="og:title" content="Jabón de {{ soap.name }} — aum.">
<meta property="og:description" content="{{ soap.tagline }}">
<meta property="og:image" content="{{ site.url }}/images/{{ soap.heroImage }}">
<meta property="og:locale" content="es_CO">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="Jabón de {{ soap.name }} — aum.">
<meta name="twitter:image" content="{{ site.url }}/images/{{ soap.heroImage }}">
{% endblock %}

{% block schema %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "aum.", "item": "{{ site.url }}/" },
        { "@type": "ListItem", "position": 2, "name": "Colección", "item": "{{ site.url }}/coleccion/" },
        { "@type": "ListItem", "position": 3, "name": "{{ soap.name }}", "item": "{{ site.url }}/coleccion/{{ soap.slug }}/" }
      ]
    },
    {
      "@type": "Product",
      "name": "Jabón de {{ soap.name }}",
      "description": "{{ soap.tagline }}",
      "image": "{{ site.url }}/images/{{ soap.heroImage }}",
      "brand": { "@type": "Brand", "name": "aum." },
      "offers": {
        "@type": "Offer",
        "price": "35000",
        "priceCurrency": "COP",
        "availability": "https://schema.org/InStock",
        "seller": { "@type": "Organization", "name": "aum." }
      }
    }
  ]
}
</script>
{% endblock %}

{{ content | safe }}
