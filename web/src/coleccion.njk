---
layout: base.njk
title: La Colección
pagecss: "/css/coleccion.css"
permalink: "/coleccion/index.html"
navLightHero: false
description: "aum. — La Colección. Siete jabones botánicos, cada uno inspirado en un centro de energía del cuerpo. Aceites esenciales puros, aceite de oliva, karité y coco. Elaborados a mano en Subachoque, Colombia."
---

{% include "components/crystal-symbols.njk" %}

    <section class="page-header" aria-labelledby="page-title">
      <div class="page-header__bg" aria-hidden="true">
        <img src="/images/Fotos_AUM-966.jpg" alt="Colección de jabones aum. con cristales naturales" loading="eager" fetchpriority="high" decoding="async" width="1667" height="2500">
      </div>
      <div class="wrap">
        <div class="page-header__inner">
          <div>
            <p class="page-header__eyebrow reveal" aria-hidden="true">Primera Colección</p>
            <h1 class="page-header__h1 reveal reveal-d1" id="page-title">La<br>Colección</h1>
          </div>
          <div class="page-header__right reveal reveal-d2">
            <p class="page-header__desc">Siete jabones botánicos elaborados a mano. Cada uno inspirado en un centro de energía del cuerpo. Base de aceite de oliva, karité y coco. Aceites esenciales puros. Un cristal natural en cada barra.</p>
            <div class="page-header__meta" role="list" aria-label="Datos de la colección">
              <div class="meta-item" role="listitem"><span class="meta-item__value">7</span><span class="meta-item__label">Jabones</span></div>
              <div class="meta-item" role="listitem"><span class="meta-item__value">110 g</span><span class="meta-item__label">Cada barra</span></div>
              <div class="meta-item" role="listitem"><span class="meta-item__value">100%</span><span class="meta-item__label">Natural</span></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <nav class="soap-nav" aria-label="Navegar a cada jabón">
      <div class="soap-nav__inner wrap">
        <a href="#cuarzo-transparente" class="soap-nav__item" style="--cx:var(--cx-quartz)"><svg class="soap-nav__dot" aria-hidden="true" focusable="false"><use href="#cx-quartz"/></svg>Cuarzo</a>
        <a href="#amatista" class="soap-nav__item" style="--cx:var(--cx-amethyst)"><svg class="soap-nav__dot" aria-hidden="true" focusable="false"><use href="#cx-amethyst"/></svg>Amatista</a>
        <a href="#sodalita" class="soap-nav__item" style="--cx:var(--cx-sodalite)"><svg class="soap-nav__dot" aria-hidden="true" focusable="false"><use href="#cx-sodalite"/></svg>Sodalita</a>
        <a href="#aventurina" class="soap-nav__item" style="--cx:var(--cx-aventurine)"><svg class="soap-nav__dot" aria-hidden="true" focusable="false"><use href="#cx-aventurine"/></svg>Aventurina</a>
        <a href="#citrino" class="soap-nav__item" style="--cx:var(--cx-citrine)"><svg class="soap-nav__dot" aria-hidden="true" focusable="false"><use href="#cx-citrine"/></svg>Citrino</a>
        <a href="#cornalina" class="soap-nav__item" style="--cx:var(--cx-carnelian)"><svg class="soap-nav__dot" aria-hidden="true" focusable="false"><use href="#cx-carnelian"/></svg>Cornalina</a>
        <a href="#jaspe-brechado" class="soap-nav__item" style="--cx:var(--cx-jasper)"><svg class="soap-nav__dot" aria-hidden="true" focusable="false"><use href="#cx-jasper"/></svg>Jaspe</a>
      </div>
    </nav>

    {% for entry in soaps %}
    <section class="soap-section" id="{{ entry.slug }}" style="--cx: var(--{{ entry.cxToken }})" aria-labelledby="soap-{{ entry.slug }}">
      <div class="soap-section__inner">
        <div class="soap-section__image">
          <img src="/images/{{ entry.heroImage }}"
            alt="Jabón de {{ entry.name }}"
            loading="lazy" decoding="async"
            width="1667" height="2500">
        </div>
        <div class="soap-section__content">
          <div class="soap-section__crystal-bar" aria-hidden="true"></div>
          <div class="soap-section__meta">
            <svg class="soap-section__crystal-dot" aria-hidden="true" focusable="false"><use href="#{{ entry.cxToken }}"/></svg>
            <span class="soap-section__number">{{ entry.number }} / 07</span>
            <span class="soap-section__center">{{ entry.center }}</span>
          </div>
          <h2 class="soap-section__name" id="soap-{{ entry.slug }}">{{ entry.name }}</h2>
          <p class="soap-section__tagline">{{ entry.tagline }}</p>
          <ul class="soap-section__oils" aria-label="Aceites esenciales">
            {% for oil in entry.oils %}
            <li>
              <span class="soap-section__oil-common">{{ oil.common }}</span>
              <span class="soap-section__oil-inci" lang="la">{{ oil.inci }}</span>
            </li>
            {% endfor %}
          </ul>
          <div class="soap-section__actions">
            <a href="/coleccion/{{ entry.slug }}/" class="btn-ghost">Ver producto <span aria-hidden="true">&rarr;</span></a>
          </div>
        </div>
      </div>
      <div class="soap-section__divider" aria-hidden="true"></div>
    </section>
    {% endfor %}


{% block schema %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Colección aum.",
  "description": "Siete jabones botánicos artesanales, cada uno inspirado en un centro de energía del cuerpo.",
  "numberOfItems": 7,
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "url": "{{ site.url }}/coleccion/cuarzo-transparente/", "name": "Jabón de Cuarzo Transparente" },
    { "@type": "ListItem", "position": 2, "url": "{{ site.url }}/coleccion/amatista/", "name": "Jabón de Amatista" },
    { "@type": "ListItem", "position": 3, "url": "{{ site.url }}/coleccion/sodalita/", "name": "Jabón de Sodalita" },
    { "@type": "ListItem", "position": 4, "url": "{{ site.url }}/coleccion/aventurina/", "name": "Jabón de Aventurina" },
    { "@type": "ListItem", "position": 5, "url": "{{ site.url }}/coleccion/citrino/", "name": "Jabón de Citrino" },
    { "@type": "ListItem", "position": 6, "url": "{{ site.url }}/coleccion/cornalina/", "name": "Jabón de Cornalina" },
    { "@type": "ListItem", "position": 7, "url": "{{ site.url }}/coleccion/jaspe-brechado/", "name": "Jabón de Jaspe Brechado" }
  ]
}
</script>
{% endblock %}

    <script src="/js/fit-text.js" defer></script>
    <script src="/js/coleccion.js" defer></script>
