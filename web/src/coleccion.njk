---
layout: base.njk
title: La Colección
pagecss: "/css/coleccion.css"
permalink: "/coleccion/index.html"
navLightHero: false
description: "aum. — La Colección. Siete jabones botánicos artesanales, cada uno inspirado en un centro de energía del cuerpo. Elaborados con aceites esenciales puros, aceite de oliva, karité y coco. Producción en Subachoque, Colombia."
---

    <section class="page-header" aria-labelledby="page-title">
      <div class="page-header__bg" aria-hidden="true">
        <img src="/images/Fotos_AUM-966.jpg" alt="Colección de jabones aum. con cristales naturales" loading="eager" fetchpriority="high" decoding="async" width="1667" height="2500">
      </div>
      <div class="wrap">
        <div class="page-header__inner">
          <div>
            <p class="page-header__eyebrow reveal" aria-hidden="true">Primera Colección</p>
            <h1 class="page-header__h1 reveal reveal-d1" id="page-title">La<br>Colección</h1>
          </div>
          <div class="page-header__right reveal reveal-d2">
            <p class="page-header__desc">Siete jabones botánicos elaborados a mano. Cada uno inspirado en un centro de energía del cuerpo. Base de aceite de oliva, karité y coco. Aceites esenciales puros. Cristal simbólico.</p>
            <div class="page-header__meta" role="list" aria-label="Datos de la colección">
              <div class="meta-item" role="listitem"><span class="meta-item__value">7</span><span class="meta-item__label">Jabones</span></div>
              <div class="meta-item" role="listitem"><span class="meta-item__value">110 g</span><span class="meta-item__label">Cada barra</span></div>
              <div class="meta-item" role="listitem"><span class="meta-item__value">100%</span><span class="meta-item__label">Natural</span></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <nav class="soap-nav" aria-label="Navegar a cada jabón">
      <div class="soap-nav__inner wrap">
        <a href="#jaspe-brechado" class="soap-nav__item" style="--cx:var(--cx-jasper)"><span class="soap-nav__dot" aria-hidden="true"></span>Jaspe</a>
        <a href="#cornalina"      class="soap-nav__item" style="--cx:var(--cx-carnelian)"><span class="soap-nav__dot" aria-hidden="true"></span>Cornalina</a>
        <a href="#citrino"        class="soap-nav__item" style="--cx:var(--cx-citrine)"><span class="soap-nav__dot" aria-hidden="true"></span>Citrino</a>
        <a href="#aventurina"     class="soap-nav__item" style="--cx:var(--cx-aventurine)"><span class="soap-nav__dot" aria-hidden="true"></span>Aventurina</a>
        <a href="#sodalita"       class="soap-nav__item" style="--cx:var(--cx-sodalite)"><span class="soap-nav__dot" aria-hidden="true"></span>Sodalita</a>
        <a href="#amatista"       class="soap-nav__item" style="--cx:var(--cx-amethyst)"><span class="soap-nav__dot" aria-hidden="true"></span>Amatista</a>
        <a href="#cuarzo-transparente" class="soap-nav__item" style="--cx:var(--cx-quartz)"><span class="soap-nav__dot" aria-hidden="true"></span>Cuarzo</a>
      </div>
    </nav>

    <div class="soaps-list wrap" role="list" aria-label="Los siete jabones de la colección">

      {% for entry in soaps %}
      <article class="soap-entry" id="{{ entry.slug }}"
        style="--cx:var(--{{ entry.cxToken }}){% if entry.cxTextToken %}; --cx-text:var(--{{ entry.cxTextToken }}){% endif %}"
        role="listitem" aria-labelledby="name-{{ entry.slug }}">
        <div class="soap-entry__inner">
          <span class="soap-entry__bg-num" aria-hidden="true">{{ entry.number }}</span>
          <div class="soap-entry__identity">
            <div class="soap-entry__identity-text">
              <p class="soap-entry__center-label">{{ entry.center }}</p>
              <h2 class="soap-entry__name" id="name-{{ entry.slug }}">{{ entry.name }}</h2>
              <p class="soap-entry__tagline">{{ entry.tagline }}</p>
            </div>
            <div class="soap-entry__pkg-thumb" aria-hidden="true">
              <img src="/images/{{ entry.packageImage }}"
                   alt=""
                   loading="lazy" decoding="async"
                   width="300" height="400">
            </div>
          </div>
          <div class="soap-entry__details">
            <div>
              <p class="soap-entry__oils-label">Aceites esenciales</p>
              <ul class="soap-entry__oils" aria-label="Aceites esenciales del Jabón de {{ entry.name }}">
                {% for oil in entry.oils %}
                <li class="soap-entry__oil">
                  <span class="soap-entry__oil-common">{{ oil.common }}</span>
                  <span class="soap-entry__oil-inci" lang="la">{{ oil.inci }}</span>
                </li>
                {% endfor %}
              </ul>
            </div>
            <div class="soap-entry__crystal" aria-label="Cristal incluido">
              <div class="soap-entry__crystal-gem">
                <span class="soap-entry__crystal-dot" aria-hidden="true"></span>
                <span class="soap-entry__crystal-name">{{ entry.name }} — {{ entry.crystalPoetic }}</span>
              </div>
              <p class="soap-entry__crystal-desc">{{ entry.crystalDescShort }}</p>
            </div>
            <div class="soap-entry__cta">
              <a href="https://wa.me/573227762560?text={{ entry.waText }}"
                 target="_blank" rel="noopener noreferrer"
                 class="btn-ghost"
                 aria-label="Pedir el Jabón de {{ entry.name }} por WhatsApp"
                 data-track="whatsapp-cta" data-track-soap="{{ entry.slug }}" data-track-location="coleccion">Pedir este jabón</a>
              <a href="/coleccion/{{ entry.slug }}/" class="btn-text-link">Ver detalle</a>
            </div>
          </div>
        </div>
        <div class="soap-entry__photo" aria-hidden="true">
          <img src="/images/{{ entry.heroImage }}"
               alt="Jabón de {{ entry.name }} con su empaque"
               loading="lazy" width="340" height="480">
        </div>
      </article>
      {% endfor %}

    </div><!-- /soaps-list -->


{% block schema %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Colección aum.",
  "description": "Siete jabones botánicos artesanales, cada uno inspirado en un centro de energía del cuerpo.",
  "numberOfItems": 7,
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "url": "{{ site.url }}/coleccion/jaspe-brechado/", "name": "Jabón de Jaspe Brechado" },
    { "@type": "ListItem", "position": 2, "url": "{{ site.url }}/coleccion/cornalina/", "name": "Jabón de Cornalina" },
    { "@type": "ListItem", "position": 3, "url": "{{ site.url }}/coleccion/citrino/", "name": "Jabón de Citrino" },
    { "@type": "ListItem", "position": 4, "url": "{{ site.url }}/coleccion/aventurina/", "name": "Jabón de Aventurina" },
    { "@type": "ListItem", "position": 5, "url": "{{ site.url }}/coleccion/sodalita/", "name": "Jabón de Sodalita" },
    { "@type": "ListItem", "position": 6, "url": "{{ site.url }}/coleccion/amatista/", "name": "Jabón de Amatista" },
    { "@type": "ListItem", "position": 7, "url": "{{ site.url }}/coleccion/cuarzo-transparente/", "name": "Jabón de Cuarzo Transparente" }
  ]
}
</script>
{% endblock %}

    <script src="/js/fit-text.js" defer></script>
    <script src="/js/coleccion.js" defer></script>
