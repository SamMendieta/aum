{
  "name": "aum-web",
  "version": "1.0.0",
  "description": "aum. botanical wellness brand website",
  "type": "module",
  "scripts": {
    "start": "eleventy --serve",
    "build": "eleventy",
    "screenshot": "node scripts/screenshot.mjs",
    "screenshot:andrea": "node scripts/screenshot.mjs --preset andrea",
    "screenshot:full": "node scripts/screenshot.mjs --preset full",
    "audit": "node scripts/responsive-audit.mjs",
    "audit:sweep": "node scripts/responsive-audit.mjs --sweep",
    "audit:andrea": "node scripts/responsive-audit.mjs --preset andrea",
    "audit:platforms": "node scripts/responsive-audit.mjs --preset platforms",
    "audit:responsive": "node scripts/responsive-audit.mjs --preset responsive",
    "audit:responsive:json": "node scripts/responsive-audit.mjs --preset responsive --json",
    "test:responsive": "npx playwright test responsive",
    "test:visual": "npx playwright test visual-regression",
    "test:all": "npx playwright test",
    "test:update-goldens": "npx playwright test visual-regression --update-snapshots"
  },
  "keywords": [],
  "author": "aum.",
  "license": "ISC",
  "dependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@11ty/eleventy-img": "^6.0.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@projectwallace/css-analyzer": "^9.6.3",
    "apca-w3": "^0.1.9",
    "axe-playwright": "^2.2.2",
    "css-tree": "^3.2.1",
    "node-vibrant": "^4.0.4",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.59.1",
    "playwright-core": "^1.59.1",
    "sharp": "^0.34.5",
    "stylelint": "^17.6.0",
    "wcag-contrast": "^3.0.0"
  }
}
