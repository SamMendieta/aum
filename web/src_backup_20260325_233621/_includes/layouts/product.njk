---
layout: base.njk
navMode: "product"
---
{% block pagecss %}
<style>:root { --cx: {{ soap.cx }}; --cx-text: {{ soap.cxText or soap.cx }}; }</style>
<link rel="stylesheet" href="/css/product.css">
{% endblock %}

{% block ogmeta %}
<meta property="og:type" content="product">
<meta property="og:title" content="Jabón de {{ soap.name }} — aum.">
<meta property="og:description" content="{{ soap.tagline }}">
<meta property="og:image" content="{{ site.url }}/images/{{ soap.heroImage }}">
<meta property="og:locale" content="es_CO">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="Jabón de {{ soap.name }} — aum.">
<meta name="twitter:image" content="{{ site.url }}/images/{{ soap.heroImage }}">
{% endblock %}

{{ content | safe }}
