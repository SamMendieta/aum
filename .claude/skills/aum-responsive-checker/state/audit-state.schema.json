{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aum-responsive-audit-state",
  "title": "aum-responsive-audit-state",
  "type": "object",
  "required": ["timestamp", "iteration", "phase"],
  "properties": {
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "iteration": {
      "type": "integer",
      "minimum": 1,
      "maximum": 3
    },
    "phase": {
      "type": "string",
      "enum": ["baseline", "diagnose", "fix", "verify", "verify-complete"]
    },
    "structural_score": {
      "type": "object",
      "properties": {
        "before": { "type": "integer", "minimum": 0, "maximum": 20 },
        "after": { "type": "integer", "minimum": 0, "maximum": 20 },
        "max": { "type": "integer", "const": 20 },
        "dimensions": {
          "type": "object",
          "properties": {
            "global_protections": { "$ref": "#/$defs/dimension" },
            "fluid_sizing": { "$ref": "#/$defs/dimension" },
            "layout_adaptability": { "$ref": "#/$defs/dimension" },
            "touch_interaction": { "$ref": "#/$defs/dimension" },
            "viewport_containment": { "$ref": "#/$defs/dimension" }
          }
        }
      }
    },
    "root_causes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "domain", "severity", "status"],
        "properties": {
          "id": { "type": "string", "pattern": "^RC-[0-9]+$" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "domain": {
            "type": "string",
            "enum": ["layout", "visual", "infrastructure"]
          },
          "skill": { "type": "string" },
          "files": { "type": "array", "items": { "type": "string" } },
          "severity": {
            "type": "string",
            "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW"]
          },
          "status": {
            "type": "string",
            "enum": ["pending", "FIXED", "BLOCKED", "SKIPPED", "FALSE_POSITIVE"]
          },
          "fix": { "type": "string" },
          "note": { "type": "string" },
          "affected_viewports": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "verification": {
      "type": "object",
      "properties": {
        "iteration": { "type": "integer" },
        "auditResponsive": { "type": "string" },
        "testResponsive": { "type": "string" },
        "screenshotLabel": { "type": "string" },
        "gate1ViewportContainment": { "type": "string", "enum": ["PASS", "FAIL"] },
        "gate2VisualRegression": { "type": "string", "enum": ["PASS", "FAIL"] },
        "gate3BrandCoherence": { "type": "string", "enum": ["PASS", "FAIL"] },
        "verdict": {
          "type": "string",
          "enum": ["PASS", "SHIP_WITH_FIXES", "NEEDS_ITERATION", "FAIL"]
        }
      }
    },
    "fixes_applied": { "type": "array", "items": { "type": "string" } },
    "fixes_reverted": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "dimension": {
      "type": "object",
      "properties": {
        "score": { "type": "integer", "minimum": 0, "maximum": 4 },
        "max": { "type": "integer", "const": 4 },
        "note": { "type": "string" }
      }
    }
  }
}
